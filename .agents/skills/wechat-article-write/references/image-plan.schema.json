{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wechat-article-write image-plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "article_type": {
      "type": "string",
      "enum": ["deep-analysis", "opinion-essay", "technical-deep-dive", "tutorial", "news-digest", "listicle", "data-story"]
    },
    "direction": {
      "type": "string",
      "enum": ["journal", "tech", "editorial", "bold", "minimal", "retro", "elegant"]
    },
    "cover": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "palette": { "type": "string" },
        "rendering": { "type": "string" },
        "text": { "type": "string" },
        "mood": { "type": "string" }
      }
    },
    "infographic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "layout": {
          "type": "string",
          "enum": ["bento-grid", "binary-comparison", "bridge", "circular-flow", "comic-strip", "comparison-matrix", "dashboard", "dense-modules", "funnel", "hierarchical-layers", "hub-spoke", "iceberg", "isometric-map", "jigsaw", "linear-progression", "periodic-table", "story-mountain", "structural-breakdown", "tree-branching", "venn-diagram", "winding-roadmap"]
        },
        "style": {
          "type": "string",
          "enum": ["aged-academia", "bold-graphic", "chalkboard", "claymation", "corporate-memphis", "craft-handmade", "cyberpunk-neon", "hand-drawn-edu", "ikea-manual", "kawaii", "knolling", "lego-brick", "morandi-journal", "origami", "pixel-art", "pop-laboratory", "retro-pop-grid", "retro-popup-pop", "storybook-watercolor", "subway-map", "technical-schematic", "ui-wireframe"]
        },
        "aspect": { "type": "string" }
      }
    },
    "illustrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["slot"],
        "properties": {
          "slot": { "type": "integer", "minimum": 1 },
          "type": { "type": "string", "enum": ["comparison", "flowchart", "framework"] },
          "style": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
